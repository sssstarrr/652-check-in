# Copy this file to .env on your server, then fill in one of the session settings.

# Single account:
# QFHY_SESSION='SESSION=replace-me; _sop_session_=replace-me'

# Directly use the desktop app's accounts.json. This is the recommended multi-account setup.
# Copy accounts.json to the repository root on the server and keep it out of git.
CHECKIN_ACCOUNTS_FILE=accounts.json

# Multi-account JSON alternative. If this is set, you can leave QFHY_SESSION and CHECKIN_ACCOUNTS_FILE empty.
# CHECKIN_ACCOUNTS_JSON=[{"student_id":"1001","name":"account1","campus":"宜宾","session":"SESSION=replace-me; _sop_session_=replace-me"}]

CHECKIN_CAMPUS=宜宾
CHECKIN_LOCATION_MODE=default
CHECKIN_LOCATION_INDEX=0
CHECKIN_RANDOM_OFFSET=false
CHECKIN_MAX_OFFSET_METERS=35
CHECKIN_TIMEOUT=20
CHECKIN_TIMEZONE=Asia/Shanghai

# If system python3 lacks venv/pip, point this to a Conda or custom Python.
# CHECKIN_PYTHON=/data/home/yourname/miniconda3/bin/python

# The maintained server cron runs at 19:05, 19:35, ..., 22:35.
CHECKIN_WINDOW_START=19:05
CHECKIN_WINDOW_END=22:35

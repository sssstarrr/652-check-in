# Copy this file to .env on your server, then fill in one of the session settings.

# Single account:
QFHY_SESSION='SESSION=replace-me; _sop_session_=replace-me'

# Multi-account alternative. If this is set, you can leave QFHY_SESSION empty.
# CHECKIN_ACCOUNTS_JSON=[{"student_id":"1001","name":"account1","campus":"宜宾","session":"SESSION=replace-me; _sop_session_=replace-me"}]

CHECKIN_CAMPUS=宜宾
CHECKIN_LOCATION_MODE=default
CHECKIN_LOCATION_INDEX=0
CHECKIN_RANDOM_OFFSET=false
CHECKIN_MAX_OFFSET_METERS=35
CHECKIN_TIMEOUT=20
CHECKIN_TIMEZONE=Asia/Shanghai

# The server script can be woken up early by cron, but it only checks in inside this window.
CHECKIN_WINDOW_START=19:31
CHECKIN_WINDOW_END=23:55
